---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const projects = [
  {
    index: "01",
    name: "duo-laguna-adapter",
    type: "LLM inference research",
    description:
      "Poolside Laguna Research Hackathon submission with Cameron Wheeler. Adapted DuoAttention to Laguna's gated attention architecture and used learned head importance for a mixed-precision KV-cache policy, reducing cache size by up to 53%.",
    tags: ["PyTorch", "LLM inference", "KV cache", "Quantization"],
    url: "https://huggingface.co/poolside-laguna-hackathon/duo-laguna-adapter",
    repo: "https://github.com/dogeplusplus/duo-attention",
    featured: true,
  },
  {
    index: "02",
    name: "bio-agents-mcp",
    type: "Life science tooling",
    description:
      "MCP servers that make protein and small-molecule data available to AI agents, with local Ollama-based testing for a practical research workflow.",
    tags: ["Python", "MCP", "PDB", "ChEMBL"],
    url: "https://github.com/dogeplusplus/bio-agents-mcp",
  },
  {
    index: "03",
    name: "jax-sentiment-analysis",
    type: "Transformer fundamentals",
    description:
      "A from-scratch Transformer implementation in JAX, Flax and Optax, applied to sentiment analysis to explore attention, training loops and model internals directly.",
    tags: ["JAX", "Flax", "Optax", "Transformers"],
    url: "https://github.com/dogeplusplus/jax-sentiment-analysis",
  },
  {
    index: "04",
    name: "group-unet",
    type: "ML research",
    description:
      "An experiment in rotation equivariance: Group Convolution U-Nets evaluated on butterfly segmentation, with tracked model comparisons and a technical write-up.",
    tags: ["PyTorch", "Group theory", "W&B"],
    url: "https://github.com/dogeplusplus/group-unet",
    article: "/writing/equivariance-properties-in-machine-learning/",
  },
  {
    index: "05",
    name: "flax-u2net",
    type: "Model implementation",
    description:
      "A from-scratch JAX and Flax implementation of U²-Net for salient-object detection, translating a non-trivial vision architecture into a functional ML stack.",
    tags: ["JAX", "Flax", "Computer vision"],
    url: "https://github.com/dogeplusplus/flax-u2net",
  },
  {
    index: "06",
    name: "ball-balancer",
    type: "Reinforcement learning",
    description:
      "Distributed PPO training for Unity ML-Agents' 3D Ball environment. Uses MPI to run parallel environments and accelerate policy learning.",
    tags: ["PyTorch", "PPO", "MPI", "Unity"],
    url: "https://github.com/dogeplusplus/ball-balancer",
  },
];

---

<SiteLayout>
  <div class="page-shell">
    <SiteHeader />

    <main>
      <section class="hero">
        <p class="eyebrow">Machine Learning Engineer · London</p>
        <h1>
          ML systems,<br />
          built to <em>last.</em>
        </h1>
        <p class="hero-copy">
          I am Albert, a machine learning engineer specialising in MLOps,
          production infrastructure and applied ML. Most of my experience is in
          life sciences, and I am interested in hard technical problems across
          the wider technology sector.
        </p>
        <div class="hero-links text-links">
          <a href="#work">Selected work ↓</a>
          <a href="https://github.com/dogeplusplus">GitHub ↗</a>
          <a href="https://www.linkedin.com/in/albert-chung-a9b549104">LinkedIn ↗</a>
        </div>
      </section>

      <section class="work ruled-section" id="work" aria-labelledby="work-title">
        <div class="section-heading work-heading">
          <div>
            <p class="section-kicker">Selected work</p>
            <h2 id="work-title">Selected <em>work.</em></h2>
          </div>
          <p>Practical tools and experiments that reflect how I like to build.</p>
        </div>

        <div class="project-grid">
          {projects.map((project) => (
            <article class:list={["project-card", { featured: project.featured }]}>
              <div class="project-top">
                <p class="mono">{project.index} / {project.type}</p>
              </div>
              <h3>{project.name}</h3>
              <p>{project.description}</p>
              <ul class="tag-list" aria-label={`${project.name} technologies`}>
                {project.tags.map((tag) => <li>{tag}</li>)}
              </ul>
              <div class="card-links">
                <a href={project.url}>{project.repo ? "View submission" : "View repository"} <span>↗</span></a>
                {project.repo && <a href={project.repo}>View fork <span>↗</span></a>}
                {project.article && <a href={project.article}>Read article <span>→</span></a>}
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="writing-callout ruled-section" aria-labelledby="writing-title">
        <p class="section-kicker">Technical writing</p>
        <div>
          <h2 id="writing-title">Notes from the workbench.</h2>
          <p>
            Longer-form explorations of model behaviour, implementation details
            and whatever else seems worth understanding properly.
          </p>
          <a class="button-link" href="/writing/">Read the notes <span>→</span></a>
        </div>
      </section>

      <section class="contact ruled-section" id="contact">
        <p class="section-kicker">Contact</p>
        <div class="contact-details">
          <p>For ML engineering roles and interesting technical problems:</p>
          <a class="email-link" href="mailto:albertswchung@gmail.com">albertswchung@gmail.com <span>↗</span></a>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</SiteLayout>
