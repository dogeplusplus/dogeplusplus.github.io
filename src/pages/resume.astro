---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const roles = [
  {
    company: "AbbVie",
    role: "Machine Learning Engineer",
    duration: "Oct 2024 – Present",
    bullets: [
      "Architected internal MLOps platform supporting 2,000+ model training experiments with hyperparameter tracking",
      "Designed Agentic LLM system to answer marketing data analysis questions and extract KPIs with tool use",
      "Deployed 50+ models for prescriptions forecasting, owning ETL optimization, drift monitoring, and retraining",
      "Automated pipeline configuration across 20+ models, saving 50 engineer hours annually",
      "Reduced time to detect production pipeline errors by 1 week via scheduled builds and monitoring alerts",
      "Refactored PySpark pipelines in Palantir Foundry, speeding up feature store development time by 2 weeks",
    ],
  },
  {
    company: "Peptone",
    role: "Machine Learning Research Engineer",
    duration: "Nov 2023 – Sep 2024",
    bullets: [
      "Fine-tuned protein transformers (pLMs) to run semantic search on antibody libraries for antigen targets",
      "Found drug hits screening 20M ligands with pLMs & GNNs on Docker/Kubernetes distributed over 40 GPUs",
      "Improved the accuracy of a biological LLM-chatbot by 10% with Retrieval-Augmented Generation (RAG)",
      "Applied Reinforcement Learning to generate thousands of molecules with desired chemical properties",
    ],
  },
  {
    company: "Perspectum",
    role: "Senior Data Scientist",
    duration: "Oct 2021 – Oct 2023",
    bullets: [
      "Scaled up the MLOps capabilities of the organisation to over 100 models using AWS Batch/ECS and Mlflow",
      "Automated ML inference infrastructure for +£5m pharma contracts via AWS Step Functions and Terraform",
      "Decreased inference time by 50% by running PyTorch model ensembles concurrently with multiprocessing",
      "Cut image analysis time by 10% by deploying streamlit web interfaces to QC model segmentations",
      "Trained large 3D vision models on 1 GPU on AWS via DeepSpeed, accelerate, gradient checkpointing",
      "Fine-tuned diffusion models using LoRA synthetic MRI images of rare anatomy for data augmentation",
    ],
  },
  {
    company: "ONI (Oxford Nanoimaging)",
    role: "Deep Learning Engineer",
    duration: "Jun 2018 – Jul 2021",
    bullets: [
      "Created video labelling tools with Python and OpenCV to support a patent for a biomarker detection assay",
      "Automated image acquisition via TensorFlow semantic segmentation models, halving label time needed",
      "Used self-supervised image-denoising PyTorch models to decrease laser power needed for images by 20%",
      "Applied transfer learning to pre-trained models, reducing the retraining data needed for new tasks by 80%",
      "Built streaming data pipelines to gather microscope telemetry using Google Cloud Functions and BigQuery",
    ],
  },
  {
    company: "MasonBreese",
    role: "Consultant Data Analyst",
    duration: "Oct 2015 – May 2018",
    bullets: [
      "Implemented ETL pipelines in SQL for 60,000 customers and over £1bn in assets for a retail bank",
      "Provided analytics in PowerBI to comply with anti-money-laundering laws, saving millions in potential fines",
      "Identified hundreds of customers that the client was at risk of churn using tree models using Scikit-Learn",
      "Cut mailing costs by 10% through SQL via entity matching, duplicate detection, and data cleaning",
      "Created customer network graphs to identify ties to high-net-worth individuals, introducing a new feature",
    ],
  },
];

const education = [
  {
    institution: "University of Warwick",
    degree: "MMath, Master of Mathematics (1st)",
    duration: "Oct 2011 – Jun 2015",
  },
  {
    institution: "Google Cloud Certified",
    degree: "Professional Data Engineer",
    duration: "Jan 2021",
  },
  {
    institution: "AWS",
    degree: "Certified Solutions Architect Associate",
    duration: "Mar 2022",
  },
];

const publications = [
  {
    title: "Improving Inverse Folding models at Protein Stability Prediction without additional Training or Data",
    workshop: "NeurIPS 2024 Machine Learning Structural Biology Workshop",
  },
  {
    title: "Optimizing protein language models with Sentence Transformers",
    workshop: "NeurIPS 2023 Machine Learning Structural Biology Workshop",
  },
];

---

<SiteLayout
  title="Albert Chung – Resume"
  description="Machine Learning Engineer with experience across MLOps, computational biology, and applied ML at AbbVie, Peptone, Perspectum, and ONI."
>
  <div class="page-shell">
    <SiteHeader active="resume" />

    <main>
      <section class="resume-hero">
        <p class="section-kicker">Resume</p>
        <h1>
          Machine learning<br />
          <em>engineering.</em>
        </h1>
        <p class="hero-copy">
          Production-minded ML research engineer with strong MLOps, infrastructure
          and applied modelling experience. Background in life sciences, pharma,
          and computational biology.
        </p>
      </section>

      <section class="experience-section ruled-section" aria-labelledby="experience-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="experience-title">Experience</p>
          </div>
        </div>

        <div class="experience-block">
          {roles.map((role) => (
            <article class="experience-entry">
              <div class="entry-header">
                <time class="entry-dates">{role.duration}</time>
                <div class="entry-title-group">
                  <span class="entry-company">{role.company}</span>
                  <span class="entry-role">{role.role}</span>
                </div>
              </div>
              <ul class="bullet-list">
                {role.bullets.map((bullet) => <li class="bullet-item">{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="education-section ruled-section" aria-labelledby="education-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="education-title">Education</p>
          </div>
        </div>

        <div class="education-grid">
          {education.map((edu) => (
            <article class="education-entry">
              <time class="entry-dates edu">{edu.duration}</time>
              <div>
                <h3>{edu.institution}</h3>
                <p>{edu.degree}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="publications-section ruled-section" aria-labelledby="publications-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="publications-title">Publications</p>
          </div>
        </div>

        <div class="publication-list">
          {publications.map((pub) => (
            <article class="publication-item">
              <span class="pub-title">{pub.title}</span>
              <span class="pub-workshop">{pub.workshop}</span>
            </article>
          ))}
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</SiteLayout>
