---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteLayout from "../layouts/SiteLayout.astro";

const roles = [
  {
    company: "AbbVie",
    role: "Machine Learning Engineer",
    duration: "Oct 2024 – Present",
    bullets: [
      "Architected an internal MLOps platform supporting 2,000+ model training experiments with hyperparameter tracking",
      "Deployed 50+ prescription forecasting models, owning ETL optimization, drift monitoring and retraining",
      "Built an agentic LLM system with tool use for marketing analytics, KPI extraction and data-question answering",
      "Cut production issue detection time by one week through scheduled builds and monitoring alerts",
    ],
  },
  {
    company: "Peptone",
    role: "Machine Learning Research Engineer",
    duration: "Nov 2023 – Sep 2024",
    bullets: [
      "Screened 20M ligands for drug hits with protein language models and GNNs distributed across 40 GPUs on Docker/Kubernetes",
      "Fine-tuned protein transformers for semantic search over antibody libraries against antigen targets",
      "Improved biological LLM-chatbot accuracy by 10% with Retrieval-Augmented Generation",
    ],
  },
  {
    company: "Perspectum",
    role: "Senior Data Scientist",
    duration: "Oct 2021 – Oct 2023",
    bullets: [
      "Scaled organizational MLOps to 100+ models using AWS Batch/ECS and MLflow",
      "Automated ML inference infrastructure for +£5m pharma contracts with AWS Step Functions and Terraform",
      "Reduced inference time by 50% by running PyTorch model ensembles concurrently with multiprocessing",
      "Trained large 3D vision models on a single GPU with DeepSpeed, Accelerate and gradient checkpointing",
    ],
  },
  {
    company: "ONI (Oxford Nanoimaging)",
    role: "Deep Learning Engineer",
    duration: "Jun 2018 – Jul 2021",
    bullets: [
      "Reduced new-task retraining data by 80% by applying transfer learning to microscopy models",
      "Decreased microscopy laser power requirements by 20% with self-supervised PyTorch image-denoising models",
      "Built Python/OpenCV video labelling tools supporting a patent for a biomarker detection assay",
    ],
  },
  {
    company: "MasonBreese",
    role: "Consultant Data Analyst",
    duration: "Oct 2015 – May 2018",
    bullets: [
      "Built SQL ETL pipelines for 60,000 customers and over £1bn in retail bank assets",
      "Delivered anti-money-laundering analytics in PowerBI, reducing exposure to millions in potential fines",
      "Cut mailing costs by 10% through SQL entity matching, duplicate detection and data cleaning",
    ],
  },
];

const impactHighlights = [
  {
    value: "2,000+",
    label: "Tracked model training experiments",
  },
  {
    value: "50+",
    label: "Forecasting models deployed",
  },
  {
    value: "20M",
    label: "Ligands screened for drug hits",
  },
  {
    value: "+£5m",
    label: "Pharma-contract infrastructure automated",
  },
];

const education = [
  {
    institution: "University of Warwick",
    degree: "MMath, Master of Mathematics (1st)",
    duration: "Oct 2011 – Jun 2015",
  },
  {
    institution: "Google Cloud Certified",
    degree: "Professional Data Engineer",
    duration: "Jan 2021",
  },
  {
    institution: "AWS",
    degree: "Certified Solutions Architect Associate",
    duration: "Mar 2022",
  },
];

const publications = [
  {
    title: "Improving Inverse Folding models at Protein Stability Prediction without additional Training or Data",
    workshop: "NeurIPS 2024 Machine Learning Structural Biology Workshop",
  },
  {
    title: "Optimizing protein language models with Sentence Transformers",
    workshop: "NeurIPS 2023 Machine Learning Structural Biology Workshop",
  },
];

---

<SiteLayout
  title="Albert Chung – Resume"
  description="Machine Learning Engineer with experience across MLOps, computational biology, and applied ML at AbbVie, Peptone, Perspectum, and ONI."
>
  <div class="page-shell">
    <SiteHeader active="resume" />

    <main>
      <section class="impact-section ruled-section" aria-labelledby="impact-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="impact-title">Selected impact</p>
          </div>
        </div>

        <div class="impact-grid">
          {impactHighlights.map((highlight) => (
            <article class="impact-item">
              <strong>{highlight.value}</strong>
              <span>{highlight.label}</span>
            </article>
          ))}
        </div>
      </section>

      <section class="experience-section ruled-section" aria-labelledby="experience-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="experience-title">Experience</p>
          </div>
        </div>

        <div class="experience-block">
          {roles.map((role) => (
            <article class="experience-entry">
              <time class="entry-dates">{role.duration}</time>
              <h2 class="entry-company">{role.company}</h2>
              <p class="entry-role">{role.role}</p>
              <ul class="bullet-list">
                {role.bullets.map((bullet) => <li class="bullet-item">{bullet}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <section class="education-section ruled-section" aria-labelledby="education-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="education-title">Education</p>
          </div>
        </div>

        <div class="education-grid">
          {education.map((edu) => (
            <article class="education-entry">
              <time class="entry-dates edu">{edu.duration}</time>
              <div>
                <h3>{edu.institution}</h3>
                <p>{edu.degree}</p>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="publications-section ruled-section" aria-labelledby="publications-title">
        <div class="section-heading">
          <div>
            <p class="section-kicker" id="publications-title">Publications</p>
          </div>
        </div>

        <div class="publication-list">
          {publications.map((pub) => (
            <article class="publication-item">
              <span class="pub-title">{pub.title}</span>
              <span class="pub-workshop">{pub.workshop}</span>
            </article>
          ))}
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</SiteLayout>
